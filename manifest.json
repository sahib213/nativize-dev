{
  "manifest_version": 3,
  "name": "Nativize - Lovable to Native Apps",
  "version": "1.1.6",
  "description": "Turn your Lovable web app into native iOS and Android apps. Generated in your browser and built in the cloud.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Nativize",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "identity", "downloads"],
  "host_permissions": [
    "https://api.github.com/*",
    "https://gaaxcbarmiwtojblkkyh.supabase.co/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://lovable.dev/*",
        "https://*.lovable.dev/*",
        "https://lovable.app/*",
        "https://*.lovable.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "src/plans.js",
        "src/billing.js",
        "src/kit-generator.js",
        "src/zip.js",
        "src/vendor/tweetnacl.js",
        "src/vendor/blake2b.js",
        "src/sealedbox.js",
        "src/github.js",
        "src/panel.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
