# Copy this file to .env.local (which is gitignored) and fill in your values.
# These secrets stay on your machine — they are NEVER deployed to nativize.dev.

# Supabase → Project Settings → API → "service_role" secret key.
# This key can read everything; keep it private, local only.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — lets the dashboard show open GitHub issues.
# Create at github.com/settings/tokens with "repo" read scope.
GITHUB_TOKEN=
GITHUB_REPO=sahib213/nativize-dev
