# Copy this file to .env.local (which is gitignored) and fill in your values.
# These secrets stay on your machine — they are NEVER deployed to nativize.dev.

# Supabase → Project Settings → API → "service_role" secret key.
# This key can read everything; keep it private, local only.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — lets the dashboard show open GitHub issues.
# Create at github.com/settings/tokens with "repo" read scope.
GITHUB_TOKEN=
GITHUB_REPO=sahib213/nativize-dev

# ---- Dashboard access ----
# Password to open the dashboard. Pick a strong one. Username is "admin".
# Required if you turn on WiFi access below.
DASHBOARD_PASSWORD=

# Leave this OUT to keep the dashboard on THIS Mac only (safest).
# Set it to 0.0.0.0 to reach the dashboard from your phone on the SAME WiFi
# (a password is then mandatory). Do NOT port-forward this to the internet.
# DASHBOARD_HOST=0.0.0.0
